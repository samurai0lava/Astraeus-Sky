{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_/backend"
        }
    },
    "rewrites": [
        { "source": "/api/:path*", "destination": "/_/backend/api/:path*" },
        { "source": "/satellite/:path*", "destination": "/_/backend/satellite/:path*" }
    ]
}